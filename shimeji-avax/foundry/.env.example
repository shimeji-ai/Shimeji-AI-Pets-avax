# Foundry deploy configuration for shimeji-avax

# Local development can use the default anvil key; override only if needed.
LOCAL_DEPLOYER_PRIVATE_KEY=
LOCAL_RPC_URL=http://127.0.0.1:8545
LOCAL_CHAIN_ID=43112

# Public deployments
DEPLOYER_PRIVATE_KEY=
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
MAINNET_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Existing contracts on Avalanche C-Chain
FUJI_USDC_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
MAINNET_USDC_ADDRESS=0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E

# Chainlink AVAX/USD feeds return 8 decimals.
FUJI_AVAX_USD_ORACLE_ADDRESS=0x5498BB86BC934c8D34FDA08E81D444153d0D06aD
MAINNET_AVAX_USD_ORACLE_ADDRESS=0x0A77230d17318075983913bC2145DB16C7366156

# Optional frontend metadata
NEXT_PUBLIC_SIWE_DOMAIN=localhost
